{
  "title": "Podcast Intelligence Pro Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "mode": {
      "title": "Scraping Mode",
      "description": "Choose how to find podcasts",
      "type": "string",
      "enum": ["search", "direct_urls", "lookup_ids"],
      "default": "search",
      "editor": "select"
    },
    "searchQuery": {
      "title": "Search Query",
      "description": "Search term for podcasts. Examples: technology, business marketing",
      "type": "string",
      "default": "technology",
      "editor": "textfield"
    },
    "country": {
      "title": "Country Code",
      "description": "iTunes country code",
      "type": "string",
      "default": "US",
      "enum": ["US", "GB", "CA", "AU", "FR", "DE", "ES", "IT", "JP"],
      "editor": "select"
    },
    "language": {
      "title": "Language (Optional)",
      "description": "Language filter",
      "type": "string",
      "editor": "textfield"
    },
    "genreId": {
      "title": "Genre ID (Optional)",
      "description": "iTunes genre ID",
      "type": "integer",
      "editor": "number"
    },
    "maxResults": {
      "title": "Max Results",
      "description": "Maximum podcasts to return",
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "default": 50,
      "editor": "number"
    },
    "feedUrls": {
      "title": "RSS Feed URLs",
      "description": "List of RSS feed URLs",
      "type": "array",
      "items": {
        "type": "string"
      },
      "editor": "stringList"
    },
    "podcastIds": {
      "title": "iTunes Podcast IDs",
      "description": "List of iTunes podcast IDs as JSON array",
      "type": "array",
      "items": {
        "type": "integer"
      },
      "editor": "json"
    },
    "includeEpisodes": {
      "title": "Include Episodes",
      "description": "Extract episode data",
      "type": "boolean",
      "default": true
    },
    "maxEpisodesPerPodcast": {
      "title": "Max Episodes Per Podcast",
      "description": "Limit episodes per podcast",
      "type": "integer",
      "minimum": 1,
      "editor": "number"
    },
    "debugMode": {
      "title": "Debug Mode",
      "description": "Enable detailed logging",
      "type": "boolean",
      "default": false
    }
  },
  "required": ["mode"]
}
